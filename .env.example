CRON_SECRET=replace-with-long-random-secret
TELEGRAM_BOT_TOKEN=123456789:replace-with-telegram-token
TELEGRAM_CHAT_ID=123456789
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

MIN_YEAR=2024
ENABLE_COPART=true
ENABLE_IAAI=true
FIRST_RUN_NOTIFY=false
MAX_RESULTS_PER_SOURCE=200
LOCAL_CHECK_HEADLESS=false

# Optional saved-search URLs. Separate multiple URLs with commas.
COPART_SEARCH_URLS=
IAAI_SEARCH_URLS=

# Optional Apify mode. If APIFY_TOKEN is set and actor IDs are omitted,
# the app defaults to the two actor IDs below.
APIFY_TOKEN=
APIFY_COPART_ACTOR_ID=parseforge/copart-public-search-scraper
APIFY_IAAI_ACTOR_ID=delectable_incubator/iaai-vehicles-scraper-low-cost

# Enables /api/debug/test-telegram outside local development.
ENABLE_DEBUG_ROUTES=false
